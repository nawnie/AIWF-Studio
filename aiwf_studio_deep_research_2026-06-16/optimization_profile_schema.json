{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiwf.local/schemas/optimization_profile.schema.json",
  "title": "AIWF Studio Optimization Profile",
  "type": "object",
  "required": [
    "profile_id",
    "profile_version",
    "pipeline_kind",
    "model_family",
    "dtype_policy",
    "attention_backend",
    "memory_policy",
    "vae_policy",
    "compile_policy",
    "quant_policy",
    "engine_policy",
    "scheduler_policy",
    "quality_modifiers",
    "fast_method",
    "compatibility"
  ],
  "properties": {
    "profile_id": {
      "type": "string",
      "description": "Stable identifier such as balanced_sdpa_fp16."
    },
    "profile_version": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "readiness": {
      "type": "string",
      "enum": [
        "production",
        "beta",
        "experimental",
        "avoid"
      ]
    },
    "pipeline_kind": {
      "type": "string",
      "enum": [
        "txt2img",
        "img2img",
        "inpaint",
        "controlnet",
        "hires",
        "fast",
        "enhance",
        "video",
        "training"
      ]
    },
    "model_family": {
      "type": "string",
      "enum": [
        "sd15",
        "sd2",
        "sdxl",
        "sdxl_turbo",
        "flux",
        "sd3",
        "unknown"
      ]
    },
    "dtype_policy": {
      "type": "object",
      "properties": {
        "unet": {
          "type": "string"
        },
        "text_encoder": {
          "type": "string"
        },
        "vae": {
          "type": "string"
        },
        "controlnet": {
          "type": "string"
        },
        "allow_tf32": {
          "type": "boolean"
        }
      }
    },
    "attention_backend": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "sdpa",
            "xformers",
            "flash",
            "sage",
            "cudnn",
            "math",
            "auto"
          ]
        },
        "fallback": {
          "type": "string"
        },
        "requires_probe": {
          "type": "boolean"
        }
      }
    },
    "memory_policy": {
      "type": "object",
      "properties": {
        "memory_format": {
          "type": "string",
          "enum": [
            "contiguous",
            "channels_last",
            "auto"
          ]
        },
        "cpu_offload": {
          "type": "string",
          "enum": [
            "none",
            "model",
            "sequential",
            "group"
          ]
        },
        "device_map": {
          "type": [
            "string",
            "object",
            "null"
          ]
        },
        "max_vram_bytes": {
          "type": [
            "integer",
            "null"
          ]
        }
      }
    },
    "vae_policy": {
      "type": "object",
      "properties": {
        "slicing": {
          "type": "string",
          "enum": [
            "off",
            "on",
            "auto"
          ]
        },
        "tiling": {
          "type": "string",
          "enum": [
            "off",
            "on",
            "auto"
          ]
        },
        "force_upcast": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "vae_asset_policy": {
          "type": "string"
        }
      }
    },
    "compile_policy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "target": {
          "type": "string",
          "enum": [
            "none",
            "unet",
            "vae_decode",
            "transformer",
            "regional",
            "multiple"
          ]
        },
        "mode": {
          "type": [
            "string",
            "null"
          ]
        },
        "fullgraph": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "dynamic": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "fixed_shapes": {
          "type": "object"
        }
      }
    },
    "quant_policy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "backend": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "bitsandbytes",
            "torchao",
            "quanto",
            "gguf",
            "modelopt",
            null
          ]
        },
        "targets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "config": {
          "type": "object"
        }
      }
    },
    "engine_policy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "backend": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "tensorrt",
            "torch_tensorrt",
            "onnxruntime",
            null
          ]
        },
        "engine_cache_key": {
          "type": [
            "string",
            "null"
          ]
        },
        "shape_profile": {
          "type": "object"
        }
      }
    },
    "scheduler_policy": {
      "type": "object",
      "properties": {
        "scheduler_class": {
          "type": "string"
        },
        "steps": {
          "type": "integer"
        },
        "guidance_scale": {
          "type": [
            "number",
            "null"
          ]
        },
        "config_overrides": {
          "type": "object"
        }
      }
    },
    "quality_modifiers": {
      "type": "object",
      "properties": {
        "freeu": {
          "type": "object"
        },
        "pag": {
          "type": "object"
        },
        "refiner": {
          "type": "object"
        },
        "clip_skip": {
          "type": [
            "integer",
            "null"
          ]
        },
        "hires_fix": {
          "type": "object"
        }
      }
    },
    "fast_method": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "method": {
          "type": "string"
        },
        "recipe_id": {
          "type": "string"
        },
        "locks_scheduler": {
          "type": "boolean"
        },
        "locks_guidance": {
          "type": "boolean"
        },
        "negative_prompt_semantics": {
          "type": "string"
        }
      }
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "requires": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "conflicts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fallback_profile_id": {
          "type": "string"
        },
        "quality_changes_output": {
          "type": "boolean"
        },
        "requires_benchmark_receipt": {
          "type": "boolean"
        }
      }
    }
  }
}