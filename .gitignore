# ============================================================
# AIWF Studio .gitignore
# Rule of thumb: if it is not needed to install or run the app,
# it does not get committed. Root stays user-facing.
# ============================================================

# --- Models & weights (multi-GB — never commit) ---
models/
model/
checkpoints/
loras/
vae/
embeddings/
*.safetensors
*.ckpt
*.pt
*.pth
*.bin
*.gguf
*.onnx
*.engine
*.h5
*.npz

# --- Python environments & caches ---
venv/
.venv/
.venv-*/
env/
engines/*/.venv*/
engines/pipeline_accel/.venv-test/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Generated output & media ---
outputs/
output/
datasets/
downloads/
cache/
tmp/
temp/
qa-screenshots/
*.mp4
*.webm
*.avi
*.mov

# --- Runtime state & logs (created by the app, machine-specific) ---
config.json
launch.json
engines.json
webui-user.bat
webui.settings.bat
logs/
*.log
*.null_guard

# --- Optional local engine checkouts (cloned by installers, not vendored) ---
engines/ComfyUI-Frame-Interpolation/
engines/nvidia-ai/
engines/nvidia-vfx-sdk-samples/
engines/nvidia-vfx-sdk/
engines/rtx-video-sdk/
engines/audio/MMAudio/
engines/ed2/EveryDream2trainer/
engines/ltx/LTX-2/
training/EveryDream2trainer/

# --- Local-only workspace bucket ---
# Non-runtime agent notes, research, scratch docs, prompt files, archives,
# and one-off handoff files all live under _local/ and never ship.
_local/
_trash/

# --- Agent / assistant working files (dev-machine only) ---
AGENTS.md
agents_runtime.md
plan.md
PROJECT_SKILLS.md
opencode.json
.hermes.md
.hermes/
.codex/
.codex-remote-attachments/
*.skill

# --- Local prompt/test inputs for smoke runs (keep in _local/) ---
prompt_image.txt
prompt_video.txt
test_image.txt
wan_dance_test.py

# --- Legacy local/non-runtime paths (keep old habits from dirtying the tree) ---
fundings/
moks findings/
outreach/
aiwf_studio_deep_research_*
AIWF_Studio_Claude_Fable_5_Roadmap_Handoff.md
prechange-*
research-agent-plan.md
requirements-*-*.md
aiwf_update_bbb1cae_studio_v4.py
AIWF_Studio/
AIWF_UPDATE_BACKUP/
C*UsersShawnDesktopshared
temp.txt
convert_wan_to_diffusers.py
copy_pipeline_for_debug.bat
read_pipeline.py
icon_file.png
*.patched.txt
*.fixed.txt
*fixed.py.txt
*-fixed.py.txt

# --- Docs exceptions (generated/benchmark data stays local) ---
docs/benchmarks/
docs/benchmark_log.jsonl
docs/projectskill-list.use-cases.json
docs/WAN_STANDALONE_RUNTIME_PLAN.md
assets/
!docs/assets/
!docs/assets/benchmarks/
!docs/assets/benchmarks/**
!docs/benchmark-reports/
!docs/benchmark-reports/**

# --- Example plugin kept local ---
plugins/example_hello/

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.lnk
